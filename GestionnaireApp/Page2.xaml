<Page x:Class="GestionnaireApp.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Créer un compte" Background="DarkGray">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Width="300" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Créer un compte" FontSize="18" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Text="Utilisateur:"/>
            <TextBox x:Name="NewUserTextBox" Height="30" Margin="0,5,0,10"/>

            <TextBlock Text="Mot de passe:"/>
            <PasswordBox x:Name="NewPassBox" Height="30" Margin="0,5,0,10"/>

            <TextBlock Text="Confirmer:"/>
            <PasswordBox x:Name="ConfirmPassBox" Height="30" Margin="0,5,0,20"/>

            <Button Content="S'inscrire" Height="40" Background="SteelBlue" Foreground="White" Click="Register_Click"/>
            <Button Content="Annuler" Margin="0,10,0,0" Background="Transparent" BorderBrush="Transparent" Click="BackToLogin_Click"/>

            <TextBlock x:Name="RegErrorText" Foreground="Red" Margin="0,10,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>