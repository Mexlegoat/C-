<Page x:Class="GestionnaireApp.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Login">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#fdfbfb" Offset="0"/>
                <GradientStop Color="#ebedee" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Background="White" Width="350" VerticalAlignment="Center" HorizontalAlignment="Center" 
                Padding="30" CornerRadius="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.1" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="StartApp" FontSize="26" FontWeight="SemiBold" Margin="0,0,0,30" 
                           HorizontalAlignment="Center" Foreground="#333333"/>

                <TextBlock Text="Nom d'utilisateur" Margin="0,0,0,5" Foreground="#666666" FontSize="12"/>
                <TextBox x:Name="UserTextBox" Margin="0,0,0,15" Height="35"/>

                <TextBlock Text="Mot de passe" Margin="0,0,0,5" Foreground="#666666" FontSize="12"/>
                <PasswordBox x:Name="PassBox" Margin="0,0,0,25" Height="35" VerticalContentAlignment="Center">
                </PasswordBox>

                <Button Content="Se Connecter" Height="40" Click="Login_Click" Cursor="Hand"/>

                <TextBlock x:Name="ErrorText" Foreground="#e81123" HorizontalAlignment="Center" Margin="0,15,0,0" FontSize="12"/>

                <Button Content="Créer un compte" Background="Transparent" Foreground="{StaticResource AccentColor}" 
                        Cursor="Hand" Margin="0,20,0,0" Click="GoToRegister_Click" HorizontalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>