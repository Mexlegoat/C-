<Window x:Class="GestionnaireApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestionnaireApp"
        mc:Ignorable="d"
        Title="StartApp" Height="500" Width="900">

    <Window.Resources>
        <local:IconConverter x:Key="IconConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- Barre de recherche -->
        <TextBox Grid.Row="0" Margin="10" Height="30" VerticalAlignment="Center"/>

        <!-- Listes -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Jeux -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Jeux" FontWeight="Bold" FontSize="14" Margin="5" HorizontalAlignment="Center"/>
                <ListBox x:Name="ListJeu" ItemsSource="{Binding ItemsJeu}" MouseDoubleClick="LaunchApp">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <Image Width="32" Height="32" Margin="0,0,5,0"
                                       Source="{Binding IconPath, Converter={StaticResource IconConverter}}"/>
                                <TextBlock Text="{Binding Nom}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Content="+" Width="30" Height="30" HorizontalAlignment="Right" Click="CreerJeu"/>
            </StackPanel>

            <Rectangle Grid.Column="1" Width="1" Fill="Gray" Margin="0,5"/>

            <!-- Travail -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Travail" FontWeight="Bold" FontSize="14" Margin="5" HorizontalAlignment="Center"/>
                <ListBox x:Name="ListTravail" ItemsSource="{Binding ItemsTravail}" MouseDoubleClick="LaunchApp">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <Image Width="32" Height="32" Margin="0,0,5,0"
                                       Source="{Binding IconPath, Converter={StaticResource IconConverter}}"/>
                                <TextBlock Text="{Binding Nom}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Content="+" Width="30" Height="30" HorizontalAlignment="Right" Click="CreerTravail"/>
            </StackPanel>

            <Rectangle Grid.Column="3" Width="1" Fill="Gray" Margin="0,5"/>

            <!-- Multimédia -->
            <StackPanel Grid.Column="4">
                <TextBlock Text="Multimédia" FontWeight="Bold" FontSize="14" Margin="5" HorizontalAlignment="Center"/>
                <ListBox x:Name="ListMm" ItemsSource="{Binding ItemsMm}" MouseDoubleClick="LaunchApp">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <Image Width="32" Height="32" Margin="0,0,5,0"
                                       Source="{Binding IconPath, Converter={StaticResource IconConverter}}"/>
                                <TextBlock Text="{Binding Nom}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Content="+" Width="30" Height="30" HorizontalAlignment="Right" Click="CreerMm"/>
            </StackPanel>
        </Grid>

        <Rectangle Grid.Row="2" Height="0" Fill="Gray" Margin="0,5"/>

        <!-- Paramètres -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Width="40" Height="40" Margin="10">
                <TextBlock Text="⚙️" FontSize="16"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>