<Window x:Class="GestionnaireApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GestionnaireApp"
        Title="StartApp" Height="650" Width="950"
        Background="{DynamicResource PrimaryBg}">

    <Window.Resources>
        <local:IconConverter x:Key="IconConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <DataTemplate x:Key="AppItemTemplate">
            <Border x:Name="InnerBox" Padding="8" Background="Transparent" CornerRadius="5" Margin="2">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Image Width="32" Height="32" Margin="0,0,10,0" Source="{Binding IconPath, Converter={StaticResource IconConverter}}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Nom}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource PrimaryText}"/>

                            <TextBlock x:Name="TxtGenre" FontSize="10" Foreground="Gray"
                                       Visibility="{Binding DataContext.CurrentUser.Preferences.ShowGenre, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Genre, StringFormat='Genre: {0}'}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=Name}" Value="ListTravail">
                                                <Setter Property="Text" Value="{Binding Langage, StringFormat='Langage: {0}'}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Text="{Binding CustomType, StringFormat='Type: {0}'}" FontSize="10" Foreground="Gray"
                                       Visibility="{Binding DataContext.CurrentUser.Preferences.ShowType, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="DetailsPanel" Visibility="Collapsed" Margin="0,10,0,0">
                        <Separator Margin="0,5" Background="#CCC"/>
                        <DockPanel Margin="5" LastChildFill="False">
                            <ComboBox x:Name="TypeSelector" ItemsSource="{Binding DataContext.AllTypes, RelativeSource={RelativeSource AncestorType=Window}}" DisplayMemberPath="Nom" Width="100" Margin="0,0,5,0"/>
                            <Button Content="Modifier" Click="AddTypeToItem_Click" Width="auto" Margin="0,0,5,0"/>
                            <Button Content="-" Click="Supprimer_Item" DockPanel.Dock="Right" Background="#FF4444" Foreground="White" FontWeight="Bold" Width="25"/>
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="DetailsPanel" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="InnerBox" Property="Background" Value="#F0F0F0"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent" MouseDown="Window_MouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" x:Name="SearchTextBox" Margin="10" Height="30" VerticalAlignment="Center" 
                 ToolTip="Rechercher une application..." TextChanged="SearchTextBox_TextChanged"/>

        <Grid Grid.Row="1" Margin="10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Jeux" FontWeight="Bold" FontSize="14" Margin="5" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryText}"/>
                <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" CornerRadius="5">
                    <ListBox x:Name="ListJeu" ItemsSource="{Binding ItemsJeu}" ItemTemplate="{StaticResource AppItemTemplate}"
                             BorderThickness="0" Background="Transparent" MouseDoubleClick="LaunchApp" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </Border>
                <Button Grid.Row="2" Content="+" Width="30" Height="30" HorizontalAlignment="Right" Click="CreerJeu" Margin="0,5,0,5"/>
            </Grid>

            <Grid Grid.Column="1" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Travail" FontWeight="Bold" FontSize="14" Margin="5" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryText}"/>
                <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" CornerRadius="5">
                    <ListBox x:Name="ListTravail" ItemsSource="{Binding ItemsTravail}" ItemTemplate="{StaticResource AppItemTemplate}"
                             BorderThickness="0" Background="Transparent" MouseDoubleClick="LaunchApp" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </Border>
                <Button Grid.Row="2" Content="+" Width="30" Height="30" HorizontalAlignment="Right" Click="CreerTravail" Margin="0,5,0,5"/>
            </Grid>

            <Grid Grid.Column="2" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Multimédia" FontWeight="Bold" FontSize="14" Margin="5" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryText}"/>
                <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" CornerRadius="5">
                    <ListBox x:Name="ListMm" ItemsSource="{Binding ItemsMm}" ItemTemplate="{StaticResource AppItemTemplate}"
                             BorderThickness="0" Background="Transparent" MouseDoubleClick="LaunchApp" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </Border>
                <Button Grid.Row="2" Content="+" Width="30" Height="30" HorizontalAlignment="Right" Click="CreerMm" Margin="0,5,0,5"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="2">
            <Button Content="Paramètres" Width="100" Height="30" Margin="10,0" HorizontalAlignment="Left" Click="Ouvrir_Param"/>
            <Button Content="+ Type" Width="60" Height="30" Margin="10,0" HorizontalAlignment="Right" Click="Ajouter_Type"/>
        </Grid>

        <Border Grid.Row="3" Margin="10" BorderBrush="#CCC" BorderThickness="1" CornerRadius="5">
            <DataGrid x:Name="AppDataGrid" ItemsSource="{Binding AllItems}" AutoGenerateColumns="False" 
                      IsReadOnly="True" Background="White" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                    <DataGridTextColumn Header="Date Ajout" Binding="{Binding DateAjoute, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="130" />
                    <DataGridTextColumn Header="Type Perso" Binding="{Binding CustomType.Nom}" Width="100"/>
                    <DataGridTextColumn Header="Chemin" Binding="{Binding Chemin}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>