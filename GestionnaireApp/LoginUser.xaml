<Page x:Class="GestionnaireApp.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Login" Background="DarkGray">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Width="300">
            <TextBlock Text="StartApp" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Text="Nom d'utilisateur:"/>
            <TextBox x:Name="UserTextBox" Margin="0,5,0,15" Height="30" VerticalContentAlignment="Center"/>

            <TextBlock Text="Mot de passe:"/>
            <PasswordBox x:Name="PassBox" Margin="0,5,0,20" Height="30" VerticalContentAlignment="Center"/>

            <Button Content="Se Connecter" Height="40" Background="Green" Foreground="White" Click="Login_Click"/>
            <TextBlock x:Name="ErrorText" Foreground="Red" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            <Button Content="Pas de compte ? Créer un compte" Background="Transparent" BorderBrush="Transparent" Foreground="Blue" Cursor="Hand" Margin="0,10,0,0" Click="GoToRegister_Click" HorizontalAlignment="Left"/>
        </StackPanel>
        
    </Grid>
</Page>