<Window x:Class="GestionnaireApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestionnaireApp"
        mc:Ignorable="d"
        Title="SettingsWindow" Height="550" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Thème" FontWeight="Bold" Margin="0,10,0,5"/>
            <Border BorderBrush="Black" BorderThickness="1" Padding="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Choix du thème: (par défaut clair)" VerticalAlignment="Center"/>
                    <RadioButton x:Name="RadioSombre" Content="Sombre" Margin="50,0,10,0"/>
                    <RadioButton x:Name="RadioClair" Content="Clair" IsChecked="True"/>
                </StackPanel>
            </Border>
            <TextBlock Text="Type:" FontWeight="Bold" Margin="0,20,0,5"/>
            <Border BorderBrush="Black" BorderThickness="1" Padding="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Afficher le type:" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <CheckBox x:Name="CheckShowType" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Genre:" FontWeight="Bold" Margin="0,20,0,5"/>
            <Border BorderBrush="Black" BorderThickness="1" Padding="10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Afficher le genre:" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <CheckBox x:Name="CheckShowGenre" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Ouvrir l'emplacement du fichier" FontWeight="Bold" Margin="0,20,0,5"/>
            <Border BorderBrush="Black" BorderThickness="1" Padding="10">
                <DockPanel>
                    <Button Content="Browse" DockPanel.Dock="Right" Width="80" Click="Browse_Click"/>
                    <TextBox x:Name="PathTextBox" IsReadOnly="True" Margin="0,0,10,0 "/>
                </DockPanel>
            </Border>

            <TextBlock Text="Executer Application (double clic)" FontWeight="Bold" Margin="0,20,0,5"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RadioExecActive" Content="Activé" Style="{StaticResource {x:Type ToggleButton}}" Width="100" Height="40"/>
                <RadioButton x:Name="RadioExecDesactive" Content="Désactivé" Style="{StaticResource {x:Type ToggleButton}}" Width="100" Height="40"/>
     
            </StackPanel>
            <Button Content="Sauvegarder" HorizontalAlignment="Right" Width="120" Height="40" Margin="0,30,0,0" Click="Save_Click"/>

        </StackPanel>
    </Grid>
</Window>
