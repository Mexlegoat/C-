<Window x:Class="GestionnaireApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Title="Gestionnaire" Height="500" Width="900">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <!-- catégories -->
            <ColumnDefinition Width="*"/>
            <!-- applications -->
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <!-- barre du haut -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 🔝 Barre du haut -->
        <StackPanel Orientation="Horizontal" Grid.ColumnSpan="2">
            <Button Content="Ajouter Catégorie" Click="AddCategory_Click"/>
            <Button Content="Ajouter Application" Click="AddApp_Click"/>
            <Button Content="Paramètres" Click="Settings_Click"/>
        </StackPanel>

        <!-- 📂 Liste des catégories -->
        <ListBox x:Name="CategoryList"
                 Grid.Row="1"
                 SelectionChanged="CategoryList_SelectionChanged"/>

        <!-- 📦 Applications -->
        <ListBox x:Name="AppList"
                 Grid.Row="1"
                 Grid.Column="1"
                 DisplayMemberPath="Nom"/>
    </Grid>
</Window>